# ==========================================
# TruthGuard AI - SaaS Backend (Render Ready)
# ==========================================

from fastapi import FastAPI
from pydantic import BaseModel
import requests

# -------------------------
# App Init
# -------------------------
app = FastAPI()

# -------------------------
# Request Schema
# -------------------------
class Input(BaseModel):
    question: str
    answer: str

# -------------------------
# Root Route (Health Check)
# -------------------------
@app.get("/")
def home():
    return {"message": "TruthGuard AI API is running 🚀"}

# -------------------------
# Evidence Fetch (Fast + Stable)
# -------------------------
def get_evidence(query):
    try:
        url = "https://api.duckduckgo.com/"
        params = {"q": query, "format": "json"}
        res = requests.get(url, params=params).json()

        if res.get("AbstractText"):
            return res["AbstractText"]

        return "No evidence found."
    except:
        return "Error fetching evidence."

# -------------------------
# Simple Similarity (FAST VERSION)
# -------------------------
def compute_score(answer, evidence):
    # lightweight heuristic (no heavy ML → faster deployment)
    answer_words = set(answer.lower().split())
    evidence_words = set(evidence.lower().split())

    if not evidence_words:
        return 0.0

    overlap = len(answer_words & evidence_words)
    score = overlap / len(answer_words) if answer_words else 0.0

    return round(score, 2)

# -------------------------
# Main API Endpoint
# -------------------------
@app.post("/verify")
def verify(data: Input):

    evidence = get_evidence(data.question)

    score = compute_score(data.answer, evidence)

    # Threshold logic
    if score >= 0.6:
        verdict = "Factual"
    elif score >= 0.3:
        verdict = "Uncertain"
    else:
        verdict = "Hallucinated"

    return {
        "question": data.question,
        "answer": data.answer,
        "evidence": evidence,
        "score": score,
        "verdict": verdict
    }
